		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ЗакупкиОбороты.Период КАК Период,
	ЗакупкиОбороты.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
	ЗакупкиОбороты.АналитикаУчетаНоменклатуры.Характеристика КАК Характеристика,
	ЗакупкиОбороты.АналитикаУчетаНоменклатуры.Серия КАК Серия,
	ЗакупкиОбороты.КоличествоОборот КАК КоличествоОборот,
	ЗакупкиОбороты.СуммаБезНДСОборот КАК СуммаБезНДСОборот,
	РАЗНОСТЬДАТ(ЗакупкиОбороты.Период, &amp;КонецПериода, МЕСЯЦ) КАК РазницаПериодов
ПОМЕСТИТЬ втПоМесяцамЗакупки
ИЗ
	РегистрНакопления.Закупки.Обороты(&amp;НачалоПериода, &amp;КонецПериода, Месяц, ) КАК ЗакупкиОбороты

СГРУППИРОВАТЬ ПО
	ЗакупкиОбороты.АналитикаУчетаНоменклатуры.Номенклатура,
	ЗакупкиОбороты.АналитикаУчетаНоменклатуры.Характеристика,
	ЗакупкиОбороты.АналитикаУчетаНоменклатуры.Серия,
	ЗакупкиОбороты.Период,
	ЗакупкиОбороты.КоличествоОборот,
	ЗакупкиОбороты.СуммаБезНДСОборот
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ДанныеПоМесяцамЗакупки.Период КАК Период,
	ДанныеПоМесяцамЗакупки.Номенклатура КАК Номенклатура,
	ДанныеПоМесяцамЗакупки.Характеристика КАК Характеристика,
	ДанныеПоМесяцамЗакупки.Серия КАК Серия,
	ДанныеПоМесяцамЗакупки.КоличествоОборот КАК КоличествоОборот,
	ДанныеПоМесяцамЗакупки.СуммаБезНДСОборот КАК СуммаБезНДСОборот,
	ВЫБОР
		КОГДА ДанныеПоМесяцамЗакупки.РазницаПериодов = 1
			ТОГДА ДанныеПоМесяцамЗакупки.СуммаБезНДСОборот / ДанныеПоМесяцамЗакупки.КоличествоОборот
		ИНАЧЕ 0
	КОНЕЦ КАК ИсторияИзмененияМесяц1,
	ВЫБОР
		КОГДА ДанныеПоМесяцамЗакупки.РазницаПериодов = 2
			ТОГДА ДанныеПоМесяцамЗакупки.СуммаБезНДСОборот / ДанныеПоМесяцамЗакупки.КоличествоОборот
		ИНАЧЕ 0
	КОНЕЦ КАК ИсторияИзмененияМесяц2,
	ВЫБОР
		КОГДА ДанныеПоМесяцамЗакупки.РазницаПериодов = 3
			ТОГДА ДанныеПоМесяцамЗакупки.СуммаБезНДСОборот / ДанныеПоМесяцамЗакупки.КоличествоОборот
		ИНАЧЕ 0
	КОНЕЦ КАК ИсторияИзмененияМесяц3,
	ВЫБОР
		КОГДА ДанныеПоМесяцамЗакупки.РазницаПериодов = 4
			ТОГДА ДанныеПоМесяцамЗакупки.СуммаБезНДСОборот / ДанныеПоМесяцамЗакупки.КоличествоОборот
		ИНАЧЕ 0
	КОНЕЦ КАК ИсторияИзмененияМесяц4,
	ВЫБОР
		КОГДА ДанныеПоМесяцамЗакупки.РазницаПериодов = 5
			ТОГДА ДанныеПоМесяцамЗакупки.СуммаБезНДСОборот / ДанныеПоМесяцамЗакупки.КоличествоОборот
		ИНАЧЕ 0
	КОНЕЦ КАК ИсторияИзмененияМесяц5,
	ВЫБОР
		КОГДА ДанныеПоМесяцамЗакупки.РазницаПериодов = 6
			ТОГДА ДанныеПоМесяцамЗакупки.СуммаБезНДСОборот / ДанныеПоМесяцамЗакупки.КоличествоОборот
		ИНАЧЕ 0
	КОНЕЦ КАК ИсторияИзмененияМесяц6,
	ВЫБОР
		КОГДА ДанныеПоМесяцамЗакупки.РазницаПериодов = 7
			ТОГДА ДанныеПоМесяцамЗакупки.СуммаБезНДСОборот / ДанныеПоМесяцамЗакупки.КоличествоОборот
		ИНАЧЕ 0
	КОНЕЦ КАК ИсторияИзмененияМесяц7,
	ВЫБОР
		КОГДА ДанныеПоМесяцамЗакупки.РазницаПериодов = 8
			ТОГДА ДанныеПоМесяцамЗакупки.СуммаБезНДСОборот / ДанныеПоМесяцамЗакупки.КоличествоОборот
		ИНАЧЕ 0
	КОНЕЦ КАК ИсторияИзмененияМесяц8,
	ВЫБОР
		КОГДА ДанныеПоМесяцамЗакупки.РазницаПериодов = 9
			ТОГДА ДанныеПоМесяцамЗакупки.СуммаБезНДСОборот / ДанныеПоМесяцамЗакупки.КоличествоОборот
		ИНАЧЕ 0
	КОНЕЦ КАК ИсторияИзмененияМесяц9,
	ВЫБОР
		КОГДА ДанныеПоМесяцамЗакупки.РазницаПериодов = 10
			ТОГДА ДанныеПоМесяцамЗакупки.СуммаБезНДСОборот / ДанныеПоМесяцамЗакупки.КоличествоОборот
		ИНАЧЕ 0
	КОНЕЦ КАК ИсторияИзмененияМесяц10,
	ВЫБОР
		КОГДА ДанныеПоМесяцамЗакупки.РазницаПериодов = 11
			ТОГДА ДанныеПоМесяцамЗакупки.СуммаБезНДСОборот / ДанныеПоМесяцамЗакупки.КоличествоОборот
		ИНАЧЕ 0
	КОНЕЦ КАК ИсторияИзмененияМесяц11
ПОМЕСТИТЬ ДанныеПоПериодам
ИЗ
	втПоМесяцамЗакупки КАК ДанныеПоМесяцамЗакупки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ТоварыКОтгрузкеОстатки.Номенклатура КАК Номенклатура,
	ТоварыКОтгрузкеОстатки.Характеристика КАК Характеристика,
	ТоварыКОтгрузкеОстатки.Назначение КАК Назначение,
	ТоварыКОтгрузкеОстатки.Склад КАК Склад,
	ТоварыКОтгрузкеОстатки.ДокументОтгрузки КАК ДокументОтгрузки,
	ТоварыКОтгрузкеОстатки.Серия КАК Серия,
	ТоварыКОтгрузкеОстатки.ВРезервеОстаток КАК ВРезервеОстаток,
	ТоварыКОтгрузкеОстатки.КОтгрузкеОстаток КАК КОтгрузкеОстаток
ПОМЕСТИТЬ втОстаткиНоменклатуры
ИЗ
	РегистрНакопления.ТоварыКОтгрузке.Остатки КАК ТоварыКОтгрузкеОстатки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ТоварыНаСкладахОстатки.Номенклатура КАК Номенклатура,
	ТоварыНаСкладахОстатки.Характеристика КАК Характеристика,
	ТоварыНаСкладахОстатки.Назначение КАК Назначение,
	ТоварыНаСкладахОстатки.Помещение КАК Помещение,
	ТоварыНаСкладахОстатки.Серия КАК Серия,
	ТоварыНаСкладахОстатки.Склад КАК Склад,
	ТоварыНаСкладахОстатки.ВНаличииОстаток КАК ВНаличииОстаток,
	ТоварыНаСкладахОстатки.КОтгрузкеОстаток КАК КОтгрузкеОстаток
ПОМЕСТИТЬ втТоварыНаСкладах
ИЗ
	РегистрНакопления.ТоварыНаСкладах.Остатки КАК ТоварыНаСкладахОстатки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЕСТЬNULL(втТоварыНаСкладах.Номенклатура, ТоварыКОтгрузке.Номенклатура) КАК Номенклатура,
	ЕСТЬNULL(втТоварыНаСкладах.Характеристика, ТоварыКОтгрузке.Характеристика) КАК Характеристика,
	ЕСТЬNULL(втТоварыНаСкладах.Серия, ТоварыКОтгрузке.Серия) КАК Серия,
	МАКСИМУМ(ЕСТЬNULL(втТоварыНаСкладах.ВНаличииОстаток, 0)) КАК ВНаличии,
	СУММА(ЕСТЬNULL(ТоварыКОтгрузке.ВРезервеОстаток, 0)) КАК ВРезерве,
	СУММА(ЕСТЬNULL(ТоварыКОтгрузке.КОтгрузкеОстаток, 0)) КАК КОтгрузке
ПОМЕСТИТЬ втОбщиеИтоги
ИЗ
	втТоварыНаСкладах КАК втТоварыНаСкладах
		ПОЛНОЕ СОЕДИНЕНИЕ втОстаткиНоменклатуры КАК ТоварыКОтгрузке
		ПО втТоварыНаСкладах.Номенклатура = ТоварыКОтгрузке.Номенклатура
			И втТоварыНаСкладах.Характеристика = ТоварыКОтгрузке.Характеристика
			И втТоварыНаСкладах.Назначение = ТоварыКОтгрузке.Назначение
			И втТоварыНаСкладах.Серия = ТоварыКОтгрузке.Серия

СГРУППИРОВАТЬ ПО
	ЕСТЬNULL(втТоварыНаСкладах.Номенклатура, ТоварыКОтгрузке.Номенклатура),
	ЕСТЬNULL(втТоварыНаСкладах.Характеристика, ТоварыКОтгрузке.Характеристика),
	ЕСТЬNULL(втТоварыНаСкладах.Серия, ТоварыКОтгрузке.Серия)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	втОбщиеИтоги.Номенклатура КАК Номенклатура,
	втОбщиеИтоги.Характеристика КАК Характеристика,
	втОбщиеИтоги.Серия КАК Серия,
	втОбщиеИтоги.ВНаличии КАК ВНаличии,
	втОбщиеИтоги.ВРезерве КАК ВРезерве,
	втОбщиеИтоги.КОтгрузке КАК КОтгрузке,
	втОбщиеИтоги.ВНаличии - втОбщиеИтоги.ВРезерве - втОбщиеИтоги.КОтгрузке КАК Доступно
ПОМЕСТИТЬ ИтогиПоДоступнымТоварам
ИЗ
	втОбщиеИтоги КАК втОбщиеИтоги
;

////////////////////////////////////////////////////////////////////////////////
УНИЧТОЖИТЬ втОстаткиНоменклатуры
;

////////////////////////////////////////////////////////////////////////////////
УНИЧТОЖИТЬ втТоварыНаСкладах
;

////////////////////////////////////////////////////////////////////////////////
УНИЧТОЖИТЬ втОбщиеИтоги
;

