////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ОбщиеДанные.Номенклатура КАК Номенклатура,
	ОбщиеДанные.Характеристика КАК Характеристика,
	МАКСИМУМ(ОбщиеДанные.Цена) КАК ПлановаяЦенаТекущегоКварталаРуб,
	МАКСИМУМ(ОбщиеДанные.ДопРасходы) КАК ТранспортВЦенеЧистаЦена,
	МАКСИМУМ(ОбщиеДанные.ДатаПоследнегоДвижения) КАК ДатаПоследнегоДвижения,
	МАКСИМУМ(ОбщиеДанные.РезервироватьНаСкладеКонечныйОстаток) КАК ОстатокВРезерве,
	СУММА(ОбщиеДанные.КоличествоКонечныйОстаток) КАК ОбщийОстаток,
	МАКСИМУМ(ОбщиеДанные.ЗаказаноОстаток) КАК КоличествоВЗаказахУПоставщика,
	МАКСИМУМ(ОбщиеДанные.КоличествоКонечныйОстаток) КАК ЦенаВАктуальныхЗаказахУПоставщика,
	МАКСИМУМ(ОбщиеДанные.СвободныйОстатокШТ) КАК СвободныйОстатокШт,
	МАКСИМУМ(ЕСТЬNULL(ДанныеАВСКлассификатор.Классификатор, "")) КАК АВС,
	СУММА(ЕСТЬNULL(ОбщиеДанные.ИсторияИзмененияМесяц1, 0)) КАК ИсторияИзмененияМесяц1,
	СУММА(ЕСТЬNULL(ОбщиеДанные.ИсторияИзмененияМесяц2, 0)) КАК ИсторияИзмененияМесяц2,
	СУММА(ЕСТЬNULL(ОбщиеДанные.ИсторияИзмененияМесяц3, 0)) КАК ИсторияИзмененияМесяц3,
	СУММА(ЕСТЬNULL(ОбщиеДанные.ИсторияИзмененияМесяц4, 0)) КАК ИсторияИзмененияМесяц4,
	СУММА(ЕСТЬNULL(ОбщиеДанные.ИсторияИзмененияМесяц5, 0)) КАК ИсторияИзмененияМесяц5,
	СУММА(ЕСТЬNULL(ОбщиеДанные.ИсторияИзмененияМесяц6, 0)) КАК ИсторияИзмененияМесяц6,
	СУММА(ЕСТЬNULL(ОбщиеДанные.ИсторияИзмененияМесяц7, 0)) КАК ИсторияИзмененияМесяц7,
	СУММА(ЕСТЬNULL(ОбщиеДанные.ИсторияИзмененияМесяц8, 0)) КАК ИсторияИзмененияМесяц8,
	СУММА(ЕСТЬNULL(ОбщиеДанные.ИсторияИзмененияМесяц9, 0)) КАК ИсторияИзмененияМесяц9,
	СУММА(ЕСТЬNULL(ОбщиеДанные.ИсторияИзмененияМесяц10, 0)) КАК ИсторияИзмененияМесяц10,
	СУММА(ЕСТЬNULL(ОбщиеДанные.ИсторияИзмененияМесяц11, 0)) КАК ИсторияИзмененияМесяц11,
	ОбщиеДанные.ВидЦены КАК ВидЦены,
	ВЫБОР
		КОГДА ОбщиеДанные.ДатаПоследнегоДвижения &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА ВЫБОР
					КОГДА РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &gt;= 0
							И РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &lt;= 90
						ТОГДА ЗНАЧЕНИЕ(Перечисление.cbr_Статусы.ОК)
					КОГДА РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &gt; 90
							И РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &lt;= 180
						ТОГДА ЗНАЧЕНИЕ(Перечисление.cbr_Статусы.Внимание)
					КОГДА РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &gt; 180
							И РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &lt;= 365
						ТОГДА ЗНАЧЕНИЕ(Перечисление.cbr_Статусы.СрочнаяРаспродажа)
					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.cbr_Статусы.Неликвид)
				КОНЕЦ
		ИНАЧЕ НЕОПРЕДЕЛЕНО
	КОНЕЦ КАК Статус,
	ВЫБОР
		КОГДА ОбщиеДанные.ДатаПоследнегоДвижения &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА ВЫБОР
					КОГДА РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &gt;= 0
							И РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &lt;= 90
						ТОГДА "От 0 до 90"
					КОГДА РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &gt; 90
							И РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &lt;= 180
						ТОГДА "От 91 до 180"
					КОГДА РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &gt; 180
							И РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &lt;= 365
						ТОГДА "От 181 до 365"
					ИНАЧЕ "От 365"
				КОНЕЦ
		ИНАЧЕ НЕОПРЕДЕЛЕНО
	КОНЕЦ КАК ДнейБезДвижения
ПОМЕСТИТЬ втОбщиеДанныеВычислениеПолей
ИЗ
	ОбщиеДанные КАК ОбщиеДанные
		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеАВСКлассификатор КАК ДанныеАВСКлассификатор
		ПО ОбщиеДанные.Номенклатура = ДанныеАВСКлассификатор.Номенклатура
			И ОбщиеДанные.Характеристика = ДанныеАВСКлассификатор.Характеристика
{ГДЕ
	ОбщиеДанные.ВидЦены.*}

СГРУППИРОВАТЬ ПО
	ОбщиеДанные.Номенклатура,
	ОбщиеДанные.Характеристика,
	ОбщиеДанные.ВидЦены,
	ВЫБОР
		КОГДА ОбщиеДанные.ДатаПоследнегоДвижения &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА ВЫБОР
					КОГДА РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &gt;= 0
							И РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &lt;= 90
						ТОГДА ЗНАЧЕНИЕ(Перечисление.cbr_Статусы.ОК)
					КОГДА РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &gt; 90
							И РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &lt;= 180
						ТОГДА ЗНАЧЕНИЕ(Перечисление.cbr_Статусы.Внимание)
					КОГДА РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &gt; 180
							И РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &lt;= 365
						ТОГДА ЗНАЧЕНИЕ(Перечисление.cbr_Статусы.СрочнаяРаспродажа)
					ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.cbr_Статусы.Неликвид)
				КОНЕЦ
		ИНАЧЕ НЕОПРЕДЕЛЕНО
	КОНЕЦ,
	ВЫБОР
		КОГДА ОбщиеДанные.ДатаПоследнегоДвижения &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА ВЫБОР
					КОГДА РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &gt;= 0
							И РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &lt;= 90
						ТОГДА "От 0 до 90"
					КОГДА РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &gt; 90
							И РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &lt;= 180
						ТОГДА "От 91 до 180"
					КОГДА РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &gt; 180
							И РАЗНОСТЬДАТ(ОбщиеДанные.ДатаПоследнегоДвижения, &amp;КонецПериода, ДЕНЬ) &lt;= 365
						ТОГДА "От 181 до 365"
					ИНАЧЕ "От 365"
				КОНЕЦ
		ИНАЧЕ НЕОПРЕДЕЛЕНО
	КОНЕЦ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	РесурсныеСпецификацииМатериалыИУслуги.Номенклатура КАК Номенклатура,
	РесурсныеСпецификацииМатериалыИУслуги.Характеристика КАК Характеристика,
	РесурсныеСпецификацииМатериалыИУслуги.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСпецификаций.Действует) КАК Действует
ПОМЕСТИТЬ втДействующиеЧастиСпецификации
ИЗ
	Справочник.РесурсныеСпецификации.МатериалыИУслуги КАК РесурсныеСпецификацииМатериалыИУслуги
ГДЕ
	(РесурсныеСпецификацииМатериалыИУслуги.Номенклатура, РесурсныеСпецификацииМатериалыИУслуги.Характеристика) В
			(ВЫБРАТЬ
				втОбщиеДанныеВычислениеПолей.Номенклатура КАК Номенклатура,
				втОбщиеДанныеВычислениеПолей.Характеристика КАК Характеристика
			ИЗ
				втОбщиеДанныеВычислениеПолей КАК втОбщиеДанныеВычислениеПолей
			СГРУППИРОВАТЬ ПО
				втОбщиеДанныеВычислениеПолей.Характеристика,
				втОбщиеДанныеВычислениеПолей.Номенклатура)
	И НЕ РесурсныеСпецификацииМатериалыИУслуги.Ссылка.ПометкаУдаления
{ГДЕ
	(РесурсныеСпецификацииМатериалыИУслуги.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСпецификаций.Действует)) КАК ПризнакВключенияВДействующиеТехКарты}
;

