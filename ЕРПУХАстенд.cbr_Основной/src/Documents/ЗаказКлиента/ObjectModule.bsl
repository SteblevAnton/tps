Функция ПолучитьСостояниеДокумента(Ссылка)
			
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РегистрСостоянийОбъектовСрезПоследних.СостояниеОбъекта КАК СостояниеОбъекта
	|ИЗ
	|	РегистрСведений.РегистрСостоянийОбъектов.СрезПоследних КАК РегистрСостоянийОбъектовСрезПоследних
	|ГДЕ
	|	РегистрСостоянийОбъектовСрезПоследних.Объект = &Объект";

	Запрос.УстановитьПараметр("Объект", Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		СостояниеОбъекта = Выборка.СостояниеОбъекта;
	КонецЦикла;
	
	Возврат СостояниеОбъекта;
			
КонецФункции //-- БаженоваЕО 12.03.2026
	
#КонецОбласти
#КонецЕсли
